# =============================================================================
# Idx Chat — CẤU HÌNH GỐC (single source)
# 1. Copy file này:  Copy-Item .env.example .env
# 2. Sửa .env (Google OAuth, API keys, …)
# 3. Docker đọc trực tiếp file này; chạy native thì: pnpm setup:env
# =============================================================================

# --- Shared (tự sync cả 3 app) ---
IDX_SERVICE_SECRET=dev-service-secret
JWT_SECRET=dev-jwt-secret-min-32-bytes-long
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# --- idx-api ---
PORT=4000
MONGODB_URI=mongodb://localhost:27017/idx_api
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
ADMIN_SEED_EMAIL=anionzo.ai@gmail.com
MODULAR_RAG_GATEWAY_URL=http://localhost:8030
USER_API_KEY=
ADMIN_API_KEY=
RESET_PASSWORD_WEBHOOK_URL=
SELF_SERVICE_PASSWORD_RESET_ENABLED=

# --- user-chat BFF ---
# Public URL used for browser OAuth redirects. Compose supplies its internal URL separately.
IDX_API_URL=http://localhost:4000
AUTH_REQUIRED=false
ALLOW_GUEST_CHAT=true
FRONTEND_URL=http://localhost:3001

# --- admin BFF ---
ADMIN_FRONTEND_URL=http://localhost:3002
