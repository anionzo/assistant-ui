MODULAR_RAG_GATEWAY_URL=http://localhost:8030
USER_API_KEY=demo-api-key
TENANT_ID=huit_admission_chatbot
TENANT_DISPLAY_NAME=HUIT Admission Chatbot
DEFAULT_CORPUS_ID=admission-chatbot-corpus
DEFAULT_CHAT_PIPELINE=huit_chat_multi_query_prod
DEFAULT_VOICE_PIPELINE=huit_voice_multi_query_prod
DEFAULT_TOP_K=5
AUTH_API_URL=http://localhost:4000
AUTH_REQUIRED=false
# Control whether unauthenticated users can send chat messages (guest/anonymous chat).
# Default follows !AUTH_REQUIRED. Set explicitly to override.
ALLOW_GUEST_CHAT=true
# E07 prod: set AUTH_REQUIRED=true (docker-compose.prod.yml sets this automatically)
JWT_SECRET=replace-me-in-real-env
FRONTEND_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idx_auth
JWT_ACCESS_TTL=3600
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
