# Shared defaults — copy slices into each app .env as needed.

# idx-api only (gateway boundary)
MODULAR_RAG_GATEWAY_URL=http://localhost:8030
USER_API_KEY=demo-api-key
ADMIN_API_KEY=demo-admin-key
IDX_SERVICE_SECRET=dev-service-secret
MONGODB_URI=mongodb://localhost:27017/idx_api
JWT_SECRET=dev-jwt-secret-min-32-bytes-long
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
FRONTEND_URL=http://localhost:3001
ADMIN_SEED_EMAIL=

# user-chat / admin (BFF → idx-api)
IDX_API_URL=http://localhost:4000
AUTH_REQUIRED=false
ALLOW_GUEST_CHAT=true
# user-chat runtime (tenant, corpus, pipelines) is stored in MongoDB app_config (admin Chat Runtime UI).