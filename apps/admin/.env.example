# Point at the same ModularRAG gateway as user-chat (not localhost unless gateway runs locally).
MODULAR_RAG_GATEWAY_URL=http://localhost:8030
# Staging: may match USER_API_KEY until IT provisions a dedicated admin key.
ADMIN_API_KEY=admin-demo-key
ADMIN_IP_ALLOWLIST=127.0.0.1,10.0.0.0/8
# Auth service — same auth-api as user-chat. JWT verification is done via API call (no local secret needed).
AUTH_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3002