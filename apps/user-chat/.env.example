IDX_API_URL=http://localhost:4000
IDX_SERVICE_SECRET=replace-me-in-local
AUTH_REQUIRED=false
# ALLOW_GUEST_CHAT controls chat without login (defaults to !AUTH_REQUIRED)
ALLOW_GUEST_CHAT=true
JWT_SECRET=dev-jwt-secret-min-32-bytes-long
FRONTEND_URL=http://localhost:3001
# Self-service forgot-password (dev default on; production default off). Admin reset always available.
SELF_SERVICE_PASSWORD_RESET_ENABLED=
# Chat runtime (tenant, corpus, pipelines) lives in MongoDB app_config — edit via admin Chat Runtime UI.