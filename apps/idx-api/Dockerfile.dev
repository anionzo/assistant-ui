FROM node:22-bookworm-slim
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps/idx-api/package.json ./apps/idx-api/
COPY apps/idx-api/scripts ./apps/idx-api/scripts
RUN pnpm install --frozen-lockfile --filter @idx/idx-api

COPY apps/idx-api ./apps/idx-api

EXPOSE 4000
CMD ["pnpm", "--filter", "@idx/idx-api", "dev"]
