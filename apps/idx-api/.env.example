PORT=4000
# Local dev (ngoài Docker): localhost. Trong docker-compose idx-api override thành mongodb://mongo:27017/idx_api
MONGODB_URI=mongodb://localhost:27017/idx_api
JWT_SECRET=dev-jwt-secret-min-32-bytes-long
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
# Google OAuth — https://console.cloud.google.com/
# 1) APIs & Services → OAuth consent screen → External → Testing
#    Thêm Test users: email Google bạn dùng login (vd. anionzo.ai@gmail.com)
# 2) APIs & Services → Credentials → Create OAuth client ID → Web application
#    Authorized redirect URIs (chỉ 1 dòng này):
#      http://localhost:4000/auth/google/callback
#    Copy Client ID + Client secret vào 2 biến dưới (KHÔNG đặt email vào secret)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
FRONTEND_URL=http://localhost:3001
# Email Google test — đăng nhập đúng email này → idx-api gán super_admin
ADMIN_SEED_EMAIL=anionzo.ai@gmail.com
MODULAR_RAG_GATEWAY_URL=http://localhost:8030
USER_API_KEY=
ADMIN_API_KEY=
IDX_SERVICE_SECRET=dev-service-secret
RESET_PASSWORD_WEBHOOK_URL=
# Self-service forgot-password (dev default on; production default off). Admin reset always available.
SELF_SERVICE_PASSWORD_RESET_ENABLED=