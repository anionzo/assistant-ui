# Harness durable layer — each project instance generates its own data.
harness.db
harness.db-wal
harness.db-shm

# Rust build output for harness tooling.
target/
dist/

# Downloaded Harness CLI binary for installed project instances.
scripts/bin/harness-cli
scripts/bin/harness-cli.exe

# Dependencies & build artifacts
node_modules/
.next/
coverage/
.turbo/
*.tsbuildinfo

# Environment (never commit secrets)
.env
.env.local

# Idx-api dev process logs
tmp_auth_api.out.log
tmp_auth_api.err.log

# Orphan folder after auth-api -> idx-api rename (Windows lock may leave empty dir)
apps/auth-api/

# Local pnpm store (should not live in repo root)
.pnpm-store/

# Agent / IDE runtime artifacts (safe to delete locally)
terminals/
agent-tools/
mcps/
_tmp_*
cookies.txt

# Harness local docs & agent config (tracked exceptions below)
docs/
!docs/DOC_MAP.md
!docs/stories/backlog.md
!docs/LOCAL_DEV.md
!docs/REPO_LAYOUT.md
AGENTS.md
.agents/
.codex/
.opencode/
history/
.env.prod
