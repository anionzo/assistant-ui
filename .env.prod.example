# Copy to .env.prod (hoặc: pnpm setup:env:prod) rồi: pnpm prod:stack

MONGODB_URI=mongodb://mongo:27017/idx_api
IDX_JWT_SECRET=change-me-to-a-32-byte-or-longer-secret
ADMIN_SEED_EMAIL=
IDX_FRONTEND_URL=http://localhost:3001
IDX_ADMIN_FRONTEND_URL=http://localhost:3002

MODULAR_RAG_GATEWAY_URL=http://host.docker.internal:8030
USER_API_KEY=demo-api-key
ADMIN_API_KEY=demo-admin-key
IDX_SERVICE_SECRET=change-me-service-secret
# Chat runtime (tenant, corpus, pipelines) is in MongoDB app_config — seed on first idx-api boot, edit in admin Chat Runtime UI.

# ALLOW_GUEST_CHAT=true allows sending messages without login (guest chat).
# Often set together with AUTH_REQUIRED.
# ALLOW_GUEST_CHAT=true
# AUTH_REQUIRED=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# No mail provider yet — keep self-service forgot-password off; use admin reset + Google login.
SELF_SERVICE_PASSWORD_RESET_ENABLED=false