{
  "name": "idx-chat",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @idx/user-chat dev",
    "setup:env": "node scripts/dev/setup-env.mjs",
    "setup:env:check": "node scripts/dev/setup-env.mjs --check",
    "stack": "docker compose up -d --build",
    "dev:stack": "docker compose up -d --build",
    "dev:stack:down": "docker compose down",
    "dev:stack:logs": "docker compose logs -f mongo idx-api idx-chat-user idx-chat-admin",
    "prod:stack": "docker compose up -d --build",
    "prod:stack:down": "docker compose down",
    "prod:stack:logs": "docker compose logs -f mongo idx-api idx-chat-user idx-chat-admin",
    "dev:admin": "pnpm --filter @idx/admin dev",
    "dev:turbo": "turbo dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:build": "node scripts/dev/build-check.mjs",
    "test:e2e": "node scripts/dev/e2e-smoke.mjs --e03",
    "test:platform": "node scripts/dev/e2e-smoke.mjs --admin",
    "typecheck": "pnpm -r --if-present typecheck",
    "prepare": "node scripts/dev/prepare.mjs"
  },
  "devDependencies": {
    "turbo": "2.10.1",
    "typescript": "^5.9.3"
  }
}
